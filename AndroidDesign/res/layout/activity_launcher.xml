<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent" >

    <qlsl.androiddesign.view.indicatorview.IndicatorView
        android:id="@id/net_indicate_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="bottom"
        android:orientation="vertical"
        android:weightSum="2" >

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="horizontal" >

            <qlsl.androiddesign.view.commonview.Button
                android:id="@+id/iv_launcher"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginLeft="@dimen/dimen_largest"
                android:layout_marginRight="@dimen/dimen_largest"
                android:background="@drawable/btn_bg_default"
                android:onClick="onClick"
                android:text="进入首页"
                android:textColor="@color/text_color_button"
                android:textSize="@dimen/dimen_button_text"
                android:visibility="gone" />
        </LinearLayout>
    </LinearLayout>

</FrameLayout>