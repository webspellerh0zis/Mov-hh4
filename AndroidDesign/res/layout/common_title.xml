<!-- 公用标题布局 -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@id/viewgroup_common_title"
    android:layout_width="fill_parent"
    android:layout_height="wrap_content"
    android:background="@color/bg_common_title_view"
    android:orientation="vertical" >

    <LinearLayout
        android:id="@id/title_view"
        android:layout_width="fill_parent"
        android:layout_height="fill_parent"
        android:layout_margin="@dimen/dimen_small"
        android:gravity="center_vertical"
        android:orientation="horizontal" >

        <qlsl.androiddesign.view.commonview.Button
            android:id="@id/btn_back"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/btn_back"
            android:onClick="onClick" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_weight="1" />

        <qlsl.androiddesign.view.commonview.TextView
            android:id="@id/tv_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:clickable="true"
            android:ellipsize="marquee"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:marqueeRepeatLimit="marquee_forever"
            android:maxEms="5"
            android:singleLine="true"
            android:text="@string/app_name"
            android:textColor="@color/text_color_title"
            android:textSize="@dimen/dimen_title_text" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_weight="1" />

        <qlsl.androiddesign.view.commonview.Button
            android:id="@id/btn_right"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="@dimen/dimen_small"
            android:layout_marginRight="@dimen/dimen_small"
            android:background="@drawable/btn_menu"
            android:drawablePadding="@dimen/dimen_smallest"
            android:onClick="onClick"
            android:textColor="@drawable/textcolor_right_button"
            android:textSize="@dimen/dimen_right_button_text" />
    </LinearLayout>

    <include layout="@layout/common_devider" />

</LinearLayout>