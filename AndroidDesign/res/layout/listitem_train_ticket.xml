            android:paddingTop="@dimen/dimen_large"
            android:singleLine="true"
            android:textColor="@color/text_color_list_item"
            android:textSize="@dimen/dimen_textview_text_small" >

            <requestFocus />
        </TextView>

        <include layout="@layout/common_devider_vertical" />

        <TextView
