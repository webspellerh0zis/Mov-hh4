<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical" >

    <View
        android:id="@+id/spaceView"
        android:layout_width="match_parent"
        android:layout_height="@dimen/dimen_middle_large"
        android:background="@color/bg_common_content_view" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/list_item"
        android:gravity="center_vertical"
        android:minHeight="50dp"
        android:orientation="horizontal"
        android:padding="@dimen/dimen_middle" >

        <qlsl.androiddesign.view.commonview.ArtTextView
            android:id="@id/tv_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginRight="@dimen/dimen_largest"
            android:singleLine="true"
            android:textColor="@color/text_color_list_item"
            android:textSize="@dimen/dimen_textview_text" />

        <include layout="@layout/common_space_horizontal" />

        <qlsl.androiddesign.view.commonview.ArtTextView
            android:id="@id/tv_value"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:maxEms="14"
            android:textColor="@color/text_color_list_item"
            android:textSize="@dimen/dimen_textview_text" />

        <ImageView
            android:id="@+id/iv_value"
            android:layout_width="@dimen/dimen_120_dip"
            android:layout_height="@dimen/dimen_120_dip"
            android:scaleType="fitXY" />

        <ImageView
            android:id="@+id/iv_value_bg"
            android:layout_width="@dimen/dimen_300_dip"
            android:layout_height="@dimen/dimen_120_dip"
            android:scaleType="fitXY" />
    </LinearLayout>

</LinearLayout>