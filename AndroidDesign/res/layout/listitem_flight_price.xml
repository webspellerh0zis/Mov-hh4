<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical" >

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal" >

        <TextView
            android:id="@+id/tv_cabinType"
            android:layout_width="120dp"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:paddingBottom="@dimen/dimen_large"
            android:paddingTop="@dimen/dimen_large"
            android:textColor="@color/text_color_list_item"
            android:textSize="@dimen/dimen_textview_text_small" />

        <include layout="@layout/common_devider_vertical" />

        <TextView
            android:id="@+id/tv_moneyType"
            android:layout_width="120dp"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:paddingBottom="@dimen/dimen_large"
            android:paddingTop="@dimen/dimen_large"
            android:textColor="@color/text_color_list_item"
            android:textSize="@dimen/dimen_textview_text_small" />

        <include layout="@layout/common_devider_vertical" />

        <TextView
            android:id="@+id/tv_singPrice"
            android:layout_width="120dp"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:paddingBottom="@dimen/dimen_large"
            android:paddingTop="@dimen/dimen_large"
            android:textColor="@color/text_color_list_item"
            android:textSize="@dimen/dimen_textview_text_small" />

        <include layout="@layout/common_devider_vertical" />

        <TextView
            android:id="@+id/tv_roundPrice"
            android:layout_width="120dp"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:paddingBottom="@dimen/dimen_large"
            android:paddingTop="@dimen/dimen_large"
            android:textColor="@color/text_color_list_item"
            android:textSize="@dimen/dimen_textview_text_small" />

        <include layout="@layout/common_devider_vertical" />

        <TextView
            android:id="@+id/tv_startDate"
            android:layout_width="120dp"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:paddingBottom="@dimen/dimen_large"
            android:paddingTop="@dimen/dimen_large"
            android:textColor="@color/text_color_list_item"
            android:textSize="@dimen/dimen_textview_text_small" />

        <include layout="@layout/common_devider_vertical" />

        <TextView
            android:id="@+id/tv_endDate"
            android:layout_width="120dp"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:paddingBottom="@dimen/dimen_large"
            android:paddingTop="@dimen/dimen_large"
            android:textColor="@color/text_color_list_item"
            android:textSize="@dimen/dimen_textview_text_small" />

        <include layout="@layout/common_devider_vertical" />

        <TextView
            android:id="@+id/tv_airline"
            android:layout_width="120dp"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:paddingBottom="@dimen/dimen_large"
            android:paddingTop="@dimen/dimen_large"
            android:textColor="@color/text_color_list_item"
            android:textSize="@dimen/dimen_textview_text_small" />

        <include layout="@layout/common_devider_vertical" />

        <TextView
            android:id="@+id/tv_rule"
            android:layout_width="120dp"
            android:layout_height="wrap_content"
            android:clickable="true"
            android:ellipsize="marquee"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:gravity="center_horizontal"
            android:marqueeRepeatLimit="marquee_forever"
            android:paddingBottom="@dimen/dimen_large"
            android:paddingTop="@dimen/dimen_large"
            android:singleLine="true"
            android:textColor="@color/text_color_list_item"
            android:textSize="@dimen/dimen_textview_text_small" />

        <include layout="@layout/common_devider_vertical" />

        <TextView
            android:id="@+id/tv_airportTax"
            android:layout_width="120dp"
            android:layout_height="wrap_content"
            android:clickable="true"
            android:ellipsize="marquee"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:gravity="center_horizontal"
            android:marqueeRepeatLimit="marquee_forever"
            android:paddingBottom="@dimen/dimen_large"
            android:paddingTop="@dimen/dimen_large"
            android:singleLine="true"
            android:textColor="@color/text_color_list_item"
            android:textSize="@dimen/dimen_textview_text_small" />

        <include layout="@layout/common_devider_vertical" />

        <TextView
            android:id="@+id/tv_fuelTax"
            android:layout_width="120dp"
            android:layout_height="wrap_content"
            android:clickable="true"
            android:ellipsize="marquee"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:gravity="center_horizontal"
            android:marqueeRepeatLimit="marquee_forever"
            android:paddingBottom="@dimen/dimen_large"
            android:paddingTop="@dimen/dimen_large"
            android:singleLine="true"
            android:textColor="@color/text_color_list_item"
            android:textSize="@dimen/dimen_textview_text_small" />

        <include layout="@layout/common_devider_vertical" />

        <TextView
            android:id="@+id/tv_basicCabinType"
            android:layout_width="120dp"
            android:layout_height="wrap_content"
            android:clickable="true"
            android:ellipsize="marquee"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:gravity="center_horizontal"
            android:marqueeRepeatLimit="marquee_forever"
            android:paddingBottom="@dimen/dimen_large"
            android:paddingTop="@dimen/dimen_large"
            android:singleLine="true"
            android:textColor="@color/text_color_list_item"
            android:textSize="@dimen/dimen_textview_text_small" />

        <include layout="@layout/common_devider_vertical" />

        <TextView
            android:id="@+id/tv_discountRate"
            android:layout_width="120dp"
            android:layout_height="wrap_content"
            android:clickable="true"
            android:ellipsize="marquee"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:gravity="center_horizontal"
            android:marqueeRepeatLimit="marquee_forever"
            android:paddingBottom="@dimen/dimen_large"
            android:paddingTop="@dimen/dimen_large"
            android:singleLine="true"
            android:textColor="@color/text_color_list_item"
            android:textSize="@dimen/dimen_textview_text_small" />

        <include layout="@layout/common_devider_vertical" />

        <TextView
            android:id="@+id/tv_yw_num"
            android:layout_width="120dp"
            android:layout_height="wrap_content"
            android:clickable="true"
            android:ellipsize="marquee"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:gravity="center_horizontal"
            android:marqueeRepeatLimit="marquee_forever"
            android:paddingBottom="@dimen/dimen_large"
            android:paddingTop="@dimen/dimen_large"
            android:singleLine="true"
            android:textColor="@color/text_color_list_item"
            android:textSize="@dimen/dimen_textview_text_small" />

        <include layout="@layout/common_devider_vertical" />

        <TextView
            android:id="@+id/tv_orgCity"
            android:layout_width="120dp"
            android:layout_height="wrap_content"
            android:clickable="true"
            android:ellipsize="marquee"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:gravity="center_horizontal"
            android:marqueeRepeatLimit="marquee_forever"
            android:paddingBottom="@dimen/dimen_large"
            android:paddingTop="@dimen/dimen_large"
            android:singleLine="true"
            android:textColor="@color/text_color_list_item"
            android:textSize="@dimen/dimen_textview_text_small" />

        <include layout="@layout/common_devider_vertical" />

        <TextView
            android:id="@+id/tv_dstcity"
            android:layout_width="120dp"
            android:layout_height="wrap_content"
            android:clickable="true"
            android:ellipsize="marquee"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:gravity="center_horizontal"
            android:marqueeRepeatLimit="marquee_forever"
            android:paddingBottom="@dimen/dimen_large"
            android:paddingTop="@dimen/dimen_large"
            android:singleLine="true"
            android:textColor="@color/text_color_list_item"
            android:textSize="@dimen/dimen_textview_text_small" />
    </LinearLayout>

    <include layout="@layout/common_devider" />

</LinearLayout>