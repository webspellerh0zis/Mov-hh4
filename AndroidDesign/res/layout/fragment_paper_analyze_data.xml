<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    android:orientation="vertical" >

    <GridView
        android:id="@+id/gridView_tag"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:horizontalSpacing="@dimen/dimen_small"
        android:listSelector="@null"
        android:numColumns="auto_fit"
        android:stretchMode="columnWidth"
        android:verticalSpacing="@dimen/dimen_small" />

    <View
        android:layout_width="match_parent"
        android:layout_height="@dimen/dimen_larger"
        android:background="@color/bg_common_content_view" />

    <include layout="@layout/common_text_image_grid" />

    <View
        android:layout_width="match_parent"
        android:layout_height="@dimen/dimen_larger"
        android:background="@color/bg_common_content_view" />

</LinearLayout>