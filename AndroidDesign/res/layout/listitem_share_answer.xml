<?xml version="1.0" encoding="UTF-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:math="http://schemas.android.com/apk/res-auto"
    android:id="@+id/list_item"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_common_content_view"
    android:onClick="onClick"
    android:orientation="vertical" >

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="@dimen/dimen_middle"
        android:background="@drawable/list_item"
        android:orientation="vertical" >

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/dimen_small"
            android:layout_marginLeft="@dimen/dimen_middle"
            android:layout_marginRight="@dimen/dimen_middle"
            android:layout_marginTop="@dimen/dimen_small"
            android:gravity="center_vertical"
            android:orientation="horizontal" >

            <ImageView
                android:id="@id/iv_icon"
                android:layout_width="@dimen/dimen_96_dip"
                android:layout_height="@dimen/dimen_96_dip"
                android:layout_gravity="center_vertical"
                android:src="@drawable/avatar_default" />

            <qlsl.androiddesign.view.commonview.ArtTextView
                android:id="@id/tv_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="@dimen/dimen_small_middle"
                android:singleLine="true"
                android:text="发送人"
                android:textColor="@color/text_color_list_item"
                android:textSize="@dimen/dimen_textview_text" />
        </LinearLayout>
    </LinearLayout>

</LinearLayout>