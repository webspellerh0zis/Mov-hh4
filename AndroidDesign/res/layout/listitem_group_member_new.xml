<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal" >

    <LinearLayout
        android:id="@id/back_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginBottom="1px"
        android:layout_marginTop="1px"
        android:background="@color/swipe_delete"
        android:gravity="center_vertical|right" >

        <qlsl.androiddesign.view.commonview.TextView
            android:id="@+id/tv_delete"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:drawableLeft="@drawable/trash"
            android:drawablePadding="@dimen/dimen_smallest"
            android:gravity="center"
            android:onClick="onClick"
            android:paddingBottom="@dimen/dimen_small"
            android:paddingLeft="@dimen/dimen_large"
            android:paddingRight="@dimen/dimen_large"
            android:paddingTop="@dimen/dimen_small"
            android:text="删除"
            android:textColor="@color/list_item_release"
            android:textSize="@dimen/dimen_textview_text_small" />
    </LinearLayout>

    <LinearLayout
        android:id="@id/front_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/list_item_release"
        android:gravity="center_vertical"
        android:orientation="vertical"
        android:padding="@dimen/dimen_small" >

        <qlsl.androiddesign.view.commonview.ArtTextView
            android:id="@+id/spaceView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/bg_common_content_view"
            android:padding="@dimen/dimen_small_middle"
            android:singleLine="true"
            android:text="圈主"
            android:textColor="@color/text_color_list_item_small"
            android:textSize="@dimen/dimen_textview_text" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/list_item"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="@dimen/dimen_middle" >

            <ImageView
                android:id="@id/iv_icon"
                android:layout_width="@dimen/dimen_96_dip"
                android:layout_height="@dimen/dimen_96_dip"
                android:layout_marginRight="@dimen/dimen_middle"
                android:src="@drawable/avatar_default" />

            <qlsl.androiddesign.view.commonview.ArtTextView
                android:id="@+id/tv_subject"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginRight="@dimen/dimen_middle"
                android:background="@color/blue"
                android:paddingBottom="@dimen/dimen_smaller"
                android:paddingLeft="@dimen/dimen_small"
                android:paddingRight="@dimen/dimen_small"
                android:paddingTop="@dimen/dimen_smaller"
                android:singleLine="true"
                android:text="科目"
                android:textColor="@color/text_color_list_item"
                android:textSize="@dimen/dimen_textview_text" />

            <qlsl.androiddesign.view.commonview.ArtTextView
                android:id="@+id/tv_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:singleLine="true"
                android:text="名字"
                android:textColor="@color/text_color_list_item"
                android:textSize="@dimen/dimen_textview_text_middle" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingLeft="@dimen/dimen_144_dip"
            android:background="@drawable/list_item"
            android:gravity="center_vertical"
            android:orientation="horizontal" >

            <ImageView
                android:id="@+id/iv_icon_parent"
                android:layout_width="@dimen/dimen_80_dip"
                android:layout_height="@dimen/dimen_80_dip"
                android:layout_marginRight="@dimen/dimen_middle"
                android:src="@drawable/avatar_default" />

            <qlsl.androiddesign.view.commonview.ArtTextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:singleLine="true"
                android:text="家长"
                android:textColor="@color/text_color_list_item"
                android:textSize="@dimen/dimen_textview_text" />
        </LinearLayout>
    </LinearLayout>

</FrameLayout>