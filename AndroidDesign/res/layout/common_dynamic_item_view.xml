<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingTop="@dimen/dimen_middle"
    android:paddingLeft="@dimen/dimen_middle"
    android:paddingRight="@dimen/dimen_middle" >

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal" >

        <ImageView
            android:id="@id/iv_icon"
            android:layout_width="@dimen/dimen_96_dip"
            android:layout_height="@dimen/dimen_96_dip"
            android:src="@drawable/avatar_default" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="@dimen/dimen_small_middle"
            android:orientation="vertical" >

            <qlsl.androiddesign.view.commonview.ArtTextView
                android:id="@id/tv_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:singleLine="true"
                android:text="发送人"
                android:textColor="@color/text_color_list_item"
                android:textSize="@dimen/dimen_textview_text" />

            <qlsl.androiddesign.view.commonview.ArtTextView
                android:id="@id/tv_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:singleLine="true"
                android:text="00:00"
                android:textColor="@color/text_color_list_item_small"
                android:textSize="@dimen/dimen_textview_text" />
        </LinearLayout>
    </LinearLayout>

    <qlsl.androiddesign.view.commonview.ArtTextView
        android:id="@id/tv_content"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/dimen_middle"
        android:text="正在加载内容"
        android:textColor="@color/text_color_list_item"
        android:textSize="@dimen/dimen_textview_text_middle" />

</LinearLayout>