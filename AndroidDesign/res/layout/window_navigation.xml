<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical" >

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="@dimen/dimen_small"
        android:orientation="vertical" >

        <Button
            android:id="@+id/btn_gaode"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/dimen_small"
            android:background="@drawable/btn_bg_default"
            android:text="高德地图"
            android:textColor="@color/text_color_button"
            android:textSize="@dimen/dimen_button_text" />

        <Button
            android:id="@+id/btn_baidu"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/dimen_small"
            android:background="@drawable/btn_bg_default"
            android:text="百度地图"
            android:textColor="@color/text_color_button"
            android:textSize="@dimen/dimen_button_text" />

        <Button
            android:id="@+id/btn_tengxun"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/dimen_small"
            android:background="@drawable/btn_bg_default"
            android:text="腾讯地图"
            android:textColor="@color/text_color_button"
            android:textSize="@dimen/dimen_button_text" />

        <Button
            android:id="@+id/btn_cancel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/btn_bg_default"
            android:text="取消"
            android:textColor="@color/text_color_button"
            android:textSize="@dimen/dimen_button_text" />
    </LinearLayout>

</LinearLayout>