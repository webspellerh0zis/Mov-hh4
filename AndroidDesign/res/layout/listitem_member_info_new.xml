<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/bg_common_content_view"
    android:gravity="center_vertical"
    android:orientation="vertical" >

    <LinearLayout
        android:id="@id/list_item"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/list_item"
        android:gravity="center_vertical"
        android:onClick="onClick"
        android:orientation="horizontal"
        android:padding="@dimen/dimen_middle" >

        <qlsl.androiddesign.view.commonview.ArtTextView
            android:id="@id/tv_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:singleLine="true"
            android:textColor="@color/text_color_text1"
            android:textSize="@dimen/dimen_textview_text_middle" />

        <include layout="@layout/common_space_horizontal" />

        <qlsl.androiddesign.view.commonview.ArtTextView
            android:id="@id/tv_value"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:singleLine="true"
            android:textColor="@color/text_color_text1"
            android:textSize="@dimen/dimen_textview_text_middle" />

        <ImageView
            android:id="@id/iv_value"
            android:layout_width="@dimen/dimen_80_dip"
            android:layout_height="@dimen/dimen_80_dip" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal" >

        <View
            android:layout_width="0dp"
            android:layout_height="0.01pt"
            android:background="@color/list_item_release" />

        <include layout="@layout/common_devider" />
    </LinearLayout>

</LinearLayout>