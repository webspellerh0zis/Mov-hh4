<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@id/emptyParentView"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal" >

    <qlsl.androiddesign.view.commonview.WrapExpandableListView
        android:id="@id/expandableListView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:cacheColorHint="@android:color/transparent"
        android:divider="@color/devider"
        android:dividerHeight="0.01pt"
        android:drawSelectorOnTop="false"
        android:fadingEdge="none"
        android:fastScrollEnabled="true"
        android:groupIndicator="@null"
        android:listSelector="@drawable/exp_list_item"
        android:scrollbars="none"
        android:scrollingCache="false"
        android:transcriptMode="normal" />

    <qlsl.androiddesign.view.commonview.TextView
        android:id="@id/tv_empty"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:onClick="onClick"
        android:text="@string/no_data"
        android:textColor="@color/darkgray"
        android:textSize="@dimen/dimen_textview_text" />

</LinearLayout>