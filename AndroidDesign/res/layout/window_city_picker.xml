<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical" >

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:orientation="horizontal" >

        <Button
            android:id="@id/btn_cancel"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@android:color/transparent"
            android:text="取消"
            android:textColor="@drawable/wheel_timebtn"
            android:textSize="@dimen/dimen_button_text" />

        <include layout="@layout/common_match_horizontal" />

        <Button
            android:id="@id/btn_ok"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@android:color/transparent"
            android:text="确定"
            android:textColor="@drawable/wheel_timebtn"
            android:textSize="@dimen/dimen_button_text" />
    </LinearLayout>

    <include layout="@layout/common_devider" />

    <qlsl.androiddesign.library.citypicker.CityPicker
        android:id="@+id/citypicker"
        android:layout_width="match_parent"
        android:layout_height="wrap_content" />

</LinearLayout>