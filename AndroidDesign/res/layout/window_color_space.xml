<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="@dimen/dimen_middle" >

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/dimen_middle_large"
        android:layout_marginLeft="@dimen/dimen_middle"
        android:layout_marginRight="@dimen/dimen_middle"
        android:gravity="center_vertical"
        android:orientation="horizontal" >

        <qlsl.androiddesign.view.commonview.TextView
            android:id="@id/tv_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/text_color_text_view"
            android:textSize="@dimen/dimen_textview_text" />

        <include layout="@layout/common_space_horizontal" />

        <ImageView
            android:id="@+id/iv_reset"
            android:layout_width="@dimen/dimen_60_dip"
            android:layout_height="@dimen/dimen_60_dip"
            android:src="@drawable/icon_refresh" />
    </LinearLayout>

    <include layout="@layout/common_devider" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/dimen_middle"
        android:layout_marginLeft="@dimen/dimen_middle"
        android:layout_marginRight="@dimen/dimen_middle"
        android:layout_marginTop="@dimen/dimen_middle_large"
        android:gravity="center_vertical"
        android:orientation="horizontal" >

        <ImageView
            android:layout_width="@dimen/dimen_50_dip"
            android:layout_height="@dimen/dimen_50_dip"
            android:layout_marginRight="@dimen/dimen_middle"
            android:src="@drawable/ic_contrast" />

        <SeekBar
            android:id="@+id/sb_guide1"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:max="200"
            android:maxHeight="@dimen/dimen_7_dip"
            android:minHeight="@dimen/dimen_7_dip"
            android:progressDrawable="@drawable/color_seekbar_color_space"
            android:thumb="@drawable/thumb_cyan"
            android:thumbOffset="0dp" />

        <qlsl.androiddesign.view.commonview.TextView
            android:id="@+id/tv_guide1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:ems="2"
            android:gravity="center_horizontal"
            android:textColor="@color/text_color_text_view"
            android:textSize="@dimen/dimen_textview_text" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="@dimen/dimen_middle"
        android:gravity="center_vertical"
        android:orientation="horizontal" >

        <ImageView
            android:layout_width="@dimen/dimen_50_dip"
            android:layout_height="@dimen/dimen_50_dip"
            android:layout_marginRight="@dimen/dimen_middle"
            android:src="@drawable/ic_brightness" />

        <SeekBar
            android:id="@+id/sb_guide2"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:max="300"
            android:maxHeight="@dimen/dimen_7_dip"
            android:minHeight="@dimen/dimen_7_dip"
            android:progressDrawable="@drawable/color_seekbar_color_space"
            android:thumb="@drawable/thumb_cyan"
            android:thumbOffset="0dp" />

        <qlsl.androiddesign.view.commonview.TextView
            android:id="@+id/tv_guide2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:ems="2"
            android:gravity="center_horizontal"
            android:textColor="@color/text_color_text_view"
            android:textSize="@dimen/dimen_textview_text" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="@dimen/dimen_middle"
        android:gravity="center_vertical"
        android:orientation="horizontal" >

        <ImageView
            android:layout_width="@dimen/dimen_50_dip"
            android:layout_height="@dimen/dimen_50_dip"
            android:layout_marginRight="@dimen/dimen_middle"
            android:src="@drawable/ic_stars" />

        <SeekBar
            android:id="@+id/sb_guide3"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:max="500"
            android:maxHeight="@dimen/dimen_7_dip"
            android:minHeight="@dimen/dimen_7_dip"
            android:progressDrawable="@drawable/color_seekbar_color_space"
            android:thumb="@drawable/thumb_cyan"
            android:thumbOffset="0dp" />

        <qlsl.androiddesign.view.commonview.TextView
            android:id="@+id/tv_guide3"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:ems="2"
            android:gravity="center_horizontal"
            android:textColor="@color/text_color_text_view"
            android:textSize="@dimen/dimen_textview_text" />
    </LinearLayout>

</LinearLayout>